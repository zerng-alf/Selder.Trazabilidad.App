<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.Views.SeleccionProcesoPage"
             Title="Menú Principal"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25" VerticalOptions="CenterAndExpand">

            <Image Source="selder_logo.png" HeightRequest="60" HorizontalOptions="Center" Margin="0,0,0,10"/>
            <Label Text="SISTEMA DE TRAZABILIDAD" FontAttributes="Bold" FontSize="20" HorizontalOptions="Center" TextColor="#333"/>
            <Label Text="Seleccione el tipo de proceso a registrar:" FontSize="14" HorizontalOptions="Center" TextColor="#666"/>

            <Frame BackgroundColor="#FFFFFF" CornerRadius="10" HasShadow="True" Padding="20">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFabricacionClicked" />
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                    <BoxView Color="DarkCyan" WidthRequest="8" CornerRadius="4" VerticalOptions="FillAndExpand"/>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="FABRICACIÓN" FontAttributes="Bold" FontSize="18" TextColor="DarkCyan"/>
                        <Label Text="Pesado, Granulado, Compresión, Recubrimiento" FontSize="12" TextColor="#777"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <Frame BackgroundColor="#FFFFFF" CornerRadius="10" HasShadow="True" Padding="20">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAcondicionamientoClicked" />
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                    <BoxView Color="#2B579A" WidthRequest="8" CornerRadius="4" VerticalOptions="FillAndExpand"/>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="ACONDICIONAMIENTO" FontAttributes="Bold" FontSize="18" TextColor="#2B579A"/>
                        <Label Text="Surtido y Acondicionamiento de Lote" FontSize="12" TextColor="#777"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <Button Text="Cerrar Sesión" 
                    Clicked="OnLogoutClicked" 
                    BackgroundColor="#D32F2F" 
                    TextColor="White" 
                    CornerRadius="8" 
                    Margin="0,20,0,0"
                    HeightRequest="45"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>