<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.LoginPage"
             Title="Acceso Selder"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">

    <Grid>
        <BoxView BackgroundColor="#2196F3" 
                 VerticalOptions="Start" 
                 HeightRequest="200"/>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="25" Spacing="0">

                <Frame CornerRadius="20" 
                       HasShadow="True" 
                       Padding="30" 
                       Margin="0,0,0,10"
                       BackgroundColor="White"
                       BorderColor="Transparent">

                    <VerticalStackLayout Spacing="20">

                        <Image Source="selder.png" 
                               HeightRequest="50" 
                               Margin="0,0,0,10"
                               HorizontalOptions="Center" />

                        <Label Text="TRAZABILIDAD" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center" 
                               TextColor="#333"/>

                        <Label Text="Inicie sesión para continuar" 
                               FontSize="14" 
                               TextColor="Gray" 
                               HorizontalOptions="Center"
                               Margin="0,-15,0,10"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Usuario" FontSize="12" TextColor="#2196F3" FontAttributes="Bold" Margin="5,0"/>
                            <Frame Padding="10,0" HeightRequest="45" CornerRadius="8" BackgroundColor="#F9F9F9" BorderColor="#DDD">
                                <Entry x:Name="TxtUsuario" 
                                       Placeholder="Ingrese su usuario"
                                       TextColor="Black"
                                       FontSize="15"
                                       Completed="OnEntryCompleted"/>
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Contraseña" FontSize="12" TextColor="#2196F3" FontAttributes="Bold" Margin="5,0"/>
                            <Frame Padding="10,0" HeightRequest="45" CornerRadius="8" BackgroundColor="#F9F9F9" BorderColor="#DDD">
                                <Entry x:Name="TxtPassword" 
                                       IsPassword="True" 
                                       Placeholder="••••••••"
                                       TextColor="Black"
                                       FontSize="15"
                                       Completed="OnEntryCompleted"/>
                            </Frame>
                        </VerticalStackLayout>

                        <Button x:Name="BtnLogin"
                                Text="INICIAR SESIÓN" 
                                Clicked="OnLoginClicked" 
                                BackgroundColor="#2196F3" 
                                TextColor="White" 
                                HeightRequest="55" 
                                CornerRadius="12" 
                                FontAttributes="Bold"
                                Margin="0,10,0,0">
                            <Button.Shadow>
                                <Shadow Brush="Black" Offset="0,5" Radius="5" Opacity="0.2"/>
                            </Button.Shadow>
                        </Button>

                        <Label x:Name="LblError" 
                               TextColor="#D32F2F" 
                               FontSize="13"
                               HorizontalOptions="Center" 
                               FontAttributes="Italic"/>

                    </VerticalStackLayout>
                </Frame>

                <Label Text="© 2026 Selder - Sistema de Trazabilidad" 
                       FontSize="11" 
                       TextColor="Gray" 
                       HorizontalOptions="Center" 
                       Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>