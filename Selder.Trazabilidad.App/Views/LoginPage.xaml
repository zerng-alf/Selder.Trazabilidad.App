<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:layout="clr-namespace:Microsoft.Maui.Controls;assembly=Microsoft.Maui.Controls"
             x:Class="Selder.Trazabilidad.App.LoginPage"
             Title="Acceso Selder"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <Image Source="dotnet_bot.png" 
                   HeightRequest="100" 
                   HorizontalOptions="Center" />

            <Label Text="Trazabilidad de Fabricación" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2196F3"/>

            <Entry x:Name="TxtUsuario" 
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Placeholder="Usuario" 
                   Keyboard="Text" />

            <Entry x:Name="TxtPassword" 
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   Placeholder="Contraseña" 
                   IsPassword="True" />

            <Button Text="ENTRAR" 
                    Clicked="OnLoginClicked" 
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="10"/>

            <Label x:Name="LblError" 
                   TextColor="Red" 
                   FontSize="14"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>