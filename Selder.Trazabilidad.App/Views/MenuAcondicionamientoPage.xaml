<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.Views.MenuAcondicionamientoPage"
             Title="Paso 1: Etapa de Trabajo"
             NavigationPage.HasNavigationBar="True"
             NavigationPage.BackButtonTitle="Salir"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salir" Clicked="OnLogoutClicked" IconImageSource="logout.png"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <Frame BackgroundColor="#2196F3" 
                   CornerRadius="15" 
                   HasShadow="True" 
                   Padding="20"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="5">
                    <Label Text="ACONDICIONAMIENTO" 
                           TextColor="White" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           Opacity="0.8"
                           HorizontalOptions="Center"/>
                    
                    <Label x:Name="LblLote" 
                           Text="Seleccione la Etapa de Trabajo"
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="White" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="ETAPAS DISPONIBLES"
                   FontSize="13" 
                   FontAttributes="Bold" 
                   TextColor="#666" 
                   Margin="5,10,0,0"/>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="15">

                <Frame Grid.Row="0" Grid.Column="0" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="SURTIDO" 
                            Clicked="OnSurtidoClicked" 
                            HeightRequest="120"
                            FontSize="12" 
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="ACONDICIONAMIENTO" 
                            Clicked="OnAcondicionamientoProcesoClicked" 
                            HeightRequest="120"
                            FontSize="11" 
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>

            </Grid>

            <Label Text="Toque la etapa para iniciar el escaneo de lotes" 
                   FontSize="12" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" 
                   Margin="0,20,0,0"
                   FontAttributes="Italic"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>