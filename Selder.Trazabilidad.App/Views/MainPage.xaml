<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.MainPage"
             Title="Panel de Control"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="15">

        <!-- 1. Cabecera de Estado Dinámica -->
        <Frame x:Name="FrameStatus" 
               Grid.Row="0"
               BackgroundColor="#444" 
               CornerRadius="15" 
               HasShadow="True" 
               Padding="20"
               BorderColor="Transparent">
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="MONITOR DE ACTIVIDAD" 
                       TextColor="White" 
                       FontSize="11" 
                       FontAttributes="Bold"
                       Opacity="0.8"
                       HorizontalOptions="Center"/>
                <Label x:Name="LblStatus" 
                       Text="ESPERANDO ESCANEO..." 
                       TextColor="White" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Frame>

        <!-- 2. Cuerpo Central: Información y Captura -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">

                <!-- Indicador de Proceso Actual -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="False" BorderColor="#DDD">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label x:Name="LblInstruccion" 
                               Text="ETAPA: PESADO - ESCANEE LOTE" 
                               TextColor="#333" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Campo de Entrada (Optimizado para Zebra) -->
                <!-- Se mantiene casi invisible para evitar el teclado de Android -->
                <Entry x:Name="TxtScanner" 
                       TextChanged="OnScannerTextChanged" 
                       HeightRequest="1" 
                       WidthRequest="1" 
                       Opacity="0.01"
                       TextColor="Transparent"
                       HorizontalOptions="Center"/>

                <!-- Visualización del Lote con Contraste Alto -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="LOTE EN PROCESO" 
                           FontSize="12" 
                           TextColor="#666" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Frame BackgroundColor="#E3F2FD" CornerRadius="15" Padding="30,15" BorderColor="#2196F3">
                        <Label x:Name="LblLoteCapturado" 
                               Text="---" 
                               TextColor="#2196F3" 
                               FontSize="40" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </Frame>
                </VerticalStackLayout>

                <!-- Ayuda Visual para el Operador -->
                <VerticalStackLayout Spacing="10" Margin="0,20">
                    <Label Text="Guía de Escaneo:" FontSize="13" TextColor="#555" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <BoxView Color="DarkCyan" HeightRequest="15" WidthRequest="15" CornerRadius="4"/>
                            <Label Text="1er Escaneo: Inicio" FontSize="10" TextColor="#777"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout HorizontalOptions="Center">
                            <BoxView Color="Green" HeightRequest="15" WidthRequest="15" CornerRadius="4"/>
                            <Label Text="2do Escaneo: Fin" FontSize="10" TextColor="#777"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 3. Acciones de Control Inferiores -->
        <Button Grid.Row="2"
                Text="LIMPIAR / NUEVA OPERACIÓN" 
                Clicked="OnResetClicked" 
                BackgroundColor="#616161" 
                TextColor="White" 
                HeightRequest="55" 
                CornerRadius="12" 
                FontAttributes="Bold"/>

    </Grid>
</ContentPage>
