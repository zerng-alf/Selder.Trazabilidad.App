<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.MainPage"
             Title="Panel de Control"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salir" Clicked="OnLogoutClicked" IconImageSource="logout.png"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20" RowSpacing="10">

        <Frame x:Name="FrameStatus" 
               Grid.Row="0"
               BackgroundColor="#444" 
               CornerRadius="15" 
               HasShadow="True" 
               Padding="20"
               BorderColor="Transparent">
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label x:Name="LblInstruccion"  
                       Text="ESCANEE LOTE" 
                       TextColor="White" 
                       FontSize="11" 
                       FontAttributes="Bold"
                       Opacity="0.8"
                       HorizontalOptions="Center"/>
                <Label x:Name="LblStatus" 
                       Text="ESPERANDO ESCANEO..." 
                       TextColor="White" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="5" VerticalOptions="Center">

                <Entry x:Name="TxtScanner" 
                       TextChanged="OnScannerTextChanged" 
                       HeightRequest="1" 
                       WidthRequest="1" 
                       Opacity="0.01"
                       TextColor="Transparent"
                       HorizontalOptions="Center"/>

                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="LOTE PROCESADO" 
                           FontSize="12" 
                           TextColor="#666" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Frame BackgroundColor="#E3F2FD" CornerRadius="15" Padding="30,15" BorderColor="#2196F3">
                        <Label x:Name="LblLoteCapturado" 
                               Text="---" 
                               TextColor="#2196F3" 
                               FontSize="40" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="ContenedorInformacion" IsVisible="False" Spacing="20" Margin="0,15,0,0">

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label x:Name="HoraInicio" 
                               Text="Hora inicio:" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="DarkCyan" 
                               HorizontalOptions="Center"/>
                        <Label x:Name="LblHoraInicio" 
                               Text="--" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="Green" 
                               HorizontalOptions="Center"
                               Margin="0,0,0,15"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label x:Name="HoraFin" 
                               Text="Hora fin:" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="DarkCyan" 
                               HorizontalOptions="Center"/>
                        <Label x:Name="LblHoraFin" 
                               Text="--" 
                               FontSize="15" 
                               FontAttributes="Bold" 
                               TextColor="Green" 
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator x:Name="LoadingIndicator"
                           Grid.Row="2"
                           IsRunning="False"
                           Color="#2196F3"
                           HorizontalOptions="Center"
                           Margin="0,0"/>

        <Button Grid.Row="3"
                x:Name="BtnReset"
                Text="LIMPIAR / NUEVA OPERACIÓN" 
                Clicked="OnResetClicked" 
                BackgroundColor="#616161" 
                TextColor="White" 
                HeightRequest="55" 
                CornerRadius="12" 
                FontAttributes="Bold"/>

    </Grid>
</ContentPage>