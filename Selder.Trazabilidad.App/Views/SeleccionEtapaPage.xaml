<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Selder.Trazabilidad.App.SeleccionEtapaPage"
             Title="Paso 1: Etapa de Trabajo"
             NavigationPage.HasNavigationBar="True"
             NavigationPage.BackButtonTitle="Salir"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salir" Clicked="OnLogoutClicked" IconImageSource="logout.png"/>
    </ContentPage.ToolbarItems>


    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Cabecera Informativa -->
            <Frame BackgroundColor="#2196F3" 
                   CornerRadius="15" 
                   HasShadow="True" 
                   Padding="20"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="5">
                    <Label Text="FABRICACIÓN" 
                           TextColor="White" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           Opacity="0.8"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblLote" 
                           Text="Seleccione la Etapa de Trabajo"
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="White" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="ETAPAS DISPONIBLES" 
                   FontSize="13" 
                   FontAttributes="Bold" 
                   TextColor="#666" 
                   Margin="5,10,0,0"/>

            <!-- Listado de Etapas -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">

                <!-- Etapa 1: Pesado -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="1. PESADO" 
                            Clicked="OnEtapaSelected" 
                            CommandParameter="PESADO" 
                            HeightRequest="120"
                            FontSize="15" 
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>

                <!-- Etapa 2: GRANULADO -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="2. GRANULADO" 
                            Clicked="OnEtapaSelected" 
                            CommandParameter="GRANULADO" 
                            HeightRequest="120"
                            FontSize="15" 
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>

                <!-- Etapa 3:  COMPRESIÓN -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="3. COMPRESIÓN"
                            Clicked="OnEtapaSelected" 
                            CommandParameter="COMPRESIÓN" 
                            HeightRequest="120"
                            FontSize="14" 
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>

                <!-- Etapa 4: RECUBRIMIENTO -->
                <Frame Grid.Row="1" Grid.Column="1" 
                       Padding="0" CornerRadius="15" HasShadow="True" BorderColor="Transparent">
                    <Button Text="4.RECUBRIMIENTO" 
                            Clicked="OnEtapaSelected" 
                            CommandParameter="RECUBRIMIENTO" 
                            HeightRequest="120"
                            FontSize="14"
                            FontAttributes="Bold"
                            BackgroundColor="White" 
                            TextColor="#2196F3"/>
                </Frame>
            </Grid>

            <Label Text="Toque la etapa para iniciar el escaneo de lotes" 
                   FontSize="12" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" 
                   Margin="0,20,0,0"
                   FontAttributes="Italic"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>